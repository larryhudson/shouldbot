{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "shouldbot-cloudflare-spike",
  "compatibility_date": "2026-07-12",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      { "class_name": "Sandbox", "name": "Sandbox" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "FlueRegistry",
        "FlueSandboxCodexWorkflow",
        "FlueSandboxOnlyWorkflow"
      ]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["Sandbox"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["FlueCodexOnlyWorkflow"]
    }
  ],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 1
    }
  ],
  "observability": {
    "enabled": true
  }
}
