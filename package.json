{
  "name": "shouldbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "flue build --target node",
    "check": "tsc --noEmit",
    "dev": "flue dev --target node",
    "sandbox:build": "docker build -f docker/sandbox.Dockerfile -t shouldbot-sandbox:dev .",
    "sandbox:smoke": "node --import tsx scripts/sandbox-smoke.ts",
    "github:verify": "node --env-file=.env --import tsx scripts/verify-github-app.ts",
    "github:clone-smoke": "node --env-file=.env --import tsx scripts/github-clone-smoke.ts",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@flue/runtime": "^1.0.0-beta.9",
    "valibot": "^1.4.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@flue/cli": "^1.0.0-beta.9",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^7.0.2"
  }
}
