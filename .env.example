# Shouldbot Node server
PORT=3000
# Public browser origin. Use localhost during development, then your Tailscale HTTPS URL.
SHOULDBOT_BASE_URL=http://localhost:3000

# Single-user GitHub authorization
# Obtain the numeric user ID with: gh api user --jq .id
SHOULDBOT_ALLOWED_GITHUB_USER_ID=replace-with-numeric-user-id
SHOULDBOT_GITHUB_CLIENT_ID=replace-with-github-app-client-id
SHOULDBOT_GITHUB_CLIENT_SECRET=replace-with-github-app-client-secret
SHOULDBOT_GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# GitHub App installation used for the private memory repository
SHOULDBOT_GITHUB_APP_ID=replace-with-numeric-app-id
SHOULDBOT_GITHUB_INSTALLATION_ID=replace-with-numeric-installation-id
SHOULDBOT_GITHUB_PRIVATE_KEY_PATH=/absolute/path/to/github-app-private-key.pem
SHOULDBOT_GITHUB_OWNER=your-github-owner
SHOULDBOT_GITHUB_REPOSITORY=shouldbot-memory
SHOULDBOT_GITHUB_DEFAULT_BRANCH=main

# Browser session signing/encryption secret
# Generate with: openssl rand -hex 32
SHOULDBOT_SESSION_SECRET=replace-with-at-least-32-random-bytes

# Pi/OpenAI Codex subscription OAuth
# Directory containing one or more Pi auth JSON files. Shouldbot selects them
# round-robin per workflow. The directory must be writable so refreshed
# credentials and the selection cursor persist across restarts.
# It must remain outside the source repo, memory repo, and agent sandbox.
SHOULDBOT_CODEX_AUTH_PATH=/absolute/path/to/.pi-auth
SHOULDBOT_CODEX_MODEL=gpt-5.4-mini
# Supported values: minimal, low, medium, high, xhigh, max
SHOULDBOT_CODEX_REASONING_LEVEL=medium

# Per-workflow Docker sandbox
SHOULDBOT_SANDBOX_IMAGE=shouldbot-sandbox:dev
SHOULDBOT_SANDBOX_MEMORY=1g
SHOULDBOT_SANDBOX_CPUS=1
SHOULDBOT_SANDBOX_PIDS_LIMIT=256
SHOULDBOT_SANDBOX_TIMEOUT_MS=900000

# Application-owned Git commit identity
SHOULDBOT_GIT_AUTHOR_NAME=Shouldbot
SHOULDBOT_GIT_AUTHOR_EMAIL=shouldbot@users.noreply.github.com
